# RelayMail SES worker environment configuration.
# Copy to .env and adjust. Never commit real secrets.

RELAYMAIL_SERVICE_NAME=relaymail-email-ses
RELAYMAIL_ENVIRONMENT=local
# RELAYMAIL_TENANT_ID=acme-corp
# RELAYMAIL_CONFIG_FILE=/etc/relaymail/relaymail-email-ses.yaml
RELAYMAIL_DRY_RUN=false

# AWS
RELAYMAIL_AWS_REGION=us-east-1
# RELAYMAIL_AWS_ENDPOINT_URL=http://localhost:4566
RELAYMAIL_SES_REGION=us-east-1
RELAYMAIL_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/relaymail-inbound
# RELAYMAIL_IDEMPOTENCY_TABLE_NAME=relaymail-idempotency
RELAYMAIL_IDEMPOTENCY_TTL_SECONDS=604800

# S3 filtering
RELAYMAIL_S3_BUCKET_ALLOWLIST=relaymail-inbound-example
# RELAYMAIL_S3_PREFIX_ALLOWLIST=incoming/
RELAYMAIL_SUPPORTED_EXTENSIONS=.eml,.emi
RELAYMAIL_MAX_EMAIL_BYTES=10485760

# SES
# RELAYMAIL_SES_CONFIGURATION_SET=relaymail-default
# RELAYMAIL_SES_SOURCE_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com
# RELAYMAIL_SES_FROM_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com
# RELAYMAIL_SES_RETURN_PATH_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com

# Processing
RELAYMAIL_PROCESSING_SUCCESS_MODE=tag
RELAYMAIL_PROCESSING_FAILURE_MODE=tag
RELAYMAIL_SUCCESS_PREFIX=processed/
RELAYMAIL_FAILURE_PREFIX=failed/
RELAYMAIL_DELETE_UNSUPPORTED_MESSAGES=true
RELAYMAIL_DELETE_INVALID_EMAIL_MESSAGES=true

# SQS
RELAYMAIL_SQS_MAX_MESSAGES=10
RELAYMAIL_SQS_WAIT_TIME_SECONDS=20
RELAYMAIL_SQS_VISIBILITY_TIMEOUT_SECONDS=300
RELAYMAIL_SQS_VISIBILITY_EXTENSION_ENABLED=true

# Runtime
RELAYMAIL_WORKER_CONCURRENCY=4
RELAYMAIL_HTTP_BIND_ADDR=0.0.0.0:8080
RELAYMAIL_SHUTDOWN_GRACE_PERIOD_SECONDS=30

# Polling fallback
RELAYMAIL_POLLING_MODE_ENABLED=false
RELAYMAIL_POLLING_INTERVAL_SECONDS=60
# RELAYMAIL_POLLING_BUCKETS=relaymail-inbound-example
# RELAYMAIL_POLLING_PREFIXES=incoming/
