# RelayMail email worker environment configuration.
# Copy to .env and adjust. Never commit real secrets.

RELAYMAIL_SERVICE_NAME=relaymail-email
RELAYMAIL_ENVIRONMENT=local
# RELAYMAIL_TENANT_ID=acme-corp
# RELAYMAIL_CONFIG_FILE=/etc/relaymail/relaymail-email-ses.yaml
RELAYMAIL_DRY_RUN=false

# Provider selection
RELAYMAIL_PRIMARY_PROVIDER=resend
RELAYMAIL_FALLBACK_PROVIDERS=postmark,smtp2go
RELAYMAIL_FALLBACK_ENABLED=true
RELAYMAIL_AWS_SES_ENABLED=false
RELAYMAIL_PROVIDER_TIMEOUT_SECONDS=10
RELAYMAIL_GLOBAL_MAX_PER_MINUTE=60

# Streams and sender domains. Replace example domains with verified domains.
RELAYMAIL_STREAMS=transactional,marketing
RELAYMAIL_STREAM_TRANSACTIONAL_ALLOWED_FROM_DOMAINS=mail.example.com
RELAYMAIL_STREAM_TRANSACTIONAL_FROM_DEFAULT="Example <no-reply@mail.example.com>"
RELAYMAIL_STREAM_TRANSACTIONAL_REPLY_TO_DEFAULT="Support <support@mail.example.com>"
RELAYMAIL_STREAM_MARKETING_ALLOWED_FROM_DOMAINS=news.example.com
RELAYMAIL_STREAM_MARKETING_FROM_DEFAULT="Example <updates@news.example.com>"
RELAYMAIL_STREAM_MARKETING_REPLY_TO_DEFAULT="Marketing <reply@news.example.com>"
RELAYMAIL_STREAM_MARKETING_REQUIRE_UNSUBSCRIBE=true
RELAYMAIL_STREAM_MARKETING_REQUIRE_CONSENT_METADATA=true

# Provider credentials. Never commit populated values.
# RESEND_API_KEY=
RELAYMAIL_RESEND_BASE_URL=https://api.resend.com
# POSTMARK_SERVER_TOKEN=
RELAYMAIL_POSTMARK_BASE_URL=https://api.postmarkapp.com
RELAYMAIL_POSTMARK_MESSAGE_STREAM=outbound
# RELAYMAIL_POSTMARK_MARKETING_MESSAGE_STREAM=broadcasts
# SMTP2GO_API_KEY=
RELAYMAIL_SMTP2GO_BASE_URL=https://api.smtp2go.com/v3

# Provider webhooks. Never commit populated values.
# RESEND_WEBHOOK_SECRET=
# POSTMARK_WEBHOOK_USERNAME=
# POSTMARK_WEBHOOK_PASSWORD=
# SMTP2GO_WEBHOOK_AUTH_TOKEN=
RELAYMAIL_WEBHOOK_STORE_RAW_PAYLOADS=false

# AWS
RELAYMAIL_AWS_REGION=us-east-1
# RELAYMAIL_AWS_ENDPOINT_URL=http://localhost:4566
RELAYMAIL_SES_REGION=us-east-1
RELAYMAIL_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/relaymail-inbound
# RELAYMAIL_IDEMPOTENCY_TABLE_NAME=relaymail-idempotency
RELAYMAIL_TRANSPORT_STATE_TABLE_NAME=relaymail-transport-state
RELAYMAIL_IDEMPOTENCY_TTL_SECONDS=604800

# S3 filtering
RELAYMAIL_S3_BUCKET_ALLOWLIST=relaymail-inbound-example
# RELAYMAIL_S3_PREFIX_ALLOWLIST=incoming/
RELAYMAIL_SUPPORTED_EXTENSIONS=.eml,.emi
RELAYMAIL_MAX_EMAIL_BYTES=10485760

# SES (optional, disabled unless RELAYMAIL_AWS_SES_ENABLED=true)
# RELAYMAIL_SES_CONFIGURATION_SET=relaymail-default
# RELAYMAIL_SES_SOURCE_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com
# RELAYMAIL_SES_FROM_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com
# RELAYMAIL_SES_RETURN_PATH_ARN=arn:aws:ses:us-east-1:123456789012:identity/example.com

# Processing
RELAYMAIL_PROCESSING_SUCCESS_MODE=tag
RELAYMAIL_PROCESSING_FAILURE_MODE=tag
RELAYMAIL_SUCCESS_PREFIX=processed/
RELAYMAIL_FAILURE_PREFIX=failed/
RELAYMAIL_DELETE_UNSUPPORTED_MESSAGES=true
RELAYMAIL_DELETE_INVALID_EMAIL_MESSAGES=true

# SQS
RELAYMAIL_SQS_MAX_MESSAGES=10
RELAYMAIL_SQS_WAIT_TIME_SECONDS=20
RELAYMAIL_SQS_VISIBILITY_TIMEOUT_SECONDS=300
RELAYMAIL_SQS_VISIBILITY_EXTENSION_ENABLED=true

# Runtime
RELAYMAIL_WORKER_CONCURRENCY=4
RELAYMAIL_HTTP_BIND_ADDR=0.0.0.0:8080
RELAYMAIL_SHUTDOWN_GRACE_PERIOD_SECONDS=30

# Polling fallback
RELAYMAIL_POLLING_MODE_ENABLED=false
RELAYMAIL_POLLING_INTERVAL_SECONDS=60
# RELAYMAIL_POLLING_BUCKETS=relaymail-inbound-example
# RELAYMAIL_POLLING_PREFIXES=incoming/
